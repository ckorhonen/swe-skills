{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SWE Skill Eval Review Result",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "reviewId",
    "skill",
    "caseId",
    "reviewer",
    "reviewedAt",
    "result",
    "sharedCriteriaResults",
    "caseQuestionResults",
    "summary"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "reviewId": {
      "type": "string",
      "minLength": 1
    },
    "skill": {
      "type": "string",
      "pattern": "^swe:"
    },
    "caseId": {
      "type": "string",
      "minLength": 1
    },
    "reviewer": {
      "type": "string",
      "minLength": 1
    },
    "reviewedAt": {
      "type": "string",
      "format": "date-time"
    },
    "result": {
      "type": "string",
      "enum": [
        "Pass",
        "Fail"
      ]
    },
    "sharedCriteriaResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "criterionId",
          "result",
          "notes"
        ],
        "properties": {
          "criterionId": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "Pass",
              "Fail"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "caseQuestionResults": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "question",
          "result",
          "notes"
        ],
        "properties": {
          "question": {
            "type": "string",
            "minLength": 1
          },
          "result": {
            "type": "string",
            "enum": [
              "Pass",
              "Fail"
            ]
          },
          "notes": {
            "type": "string"
          }
        }
      }
    },
    "summary": {
      "type": "string"
    }
  }
}

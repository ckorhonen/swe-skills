{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SWE Skill Eval Cases",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "skill",
    "cases"
  ],
  "properties": {
    "schemaVersion": {
      "type": "integer",
      "const": 1
    },
    "skill": {
      "type": "string",
      "pattern": "^swe:"
    },
    "cases": {
      "type": "array",
      "minItems": 2,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "id",
          "title",
          "tags",
          "user_request",
          "context",
          "artifact_requirements",
          "shared_criteria",
          "review_questions"
        ],
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "tags": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "user_request": {
            "type": "string",
            "minLength": 1
          },
          "context": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "repo_path"
            ],
            "properties": {
              "repo_path": {
                "type": "string",
                "minLength": 1
              },
              "notes": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              },
              "available_artifacts": {
                "type": "array",
                "items": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "artifact_requirements": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "shared_criteria": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "static_checks": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "review_questions": {
            "type": "array",
            "minItems": 2,
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    }
  }
}
